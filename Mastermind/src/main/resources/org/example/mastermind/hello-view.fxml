<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.mastermind.MastermindView"
            style="-fx-background-color: #f4f4f4;">

  <!-- HEADER -->
  <top>
    <VBox spacing="6" style="-fx-background-color: #2b2b2b; -fx-padding: 15;">
      <Label fx:id="titleLabel"
             style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
      <Label fx:id="infoLabel"
             style="-fx-text-fill: #aaa; -fx-font-size: 12px;"/>
      <Label fx:id="triesLabel"
             style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4caf50;"/>
    </VBox>
  </top>

  <!-- MITTE: Spielfeld + Seitenleiste -->
  <center>
    <HBox spacing="0">

      <!-- Spielfeld -->
      <VBox spacing="8" HBox.hgrow="ALWAYS">
        <padding><Insets top="12" right="15" bottom="8" left="15"/></padding>
        <Label text="Bisherige Versuche:"
               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        <ScrollPane fitToWidth="true" prefHeight="300"
                    style="-fx-background: white; -fx-background-color: white;">
          <content>
            <VBox fx:id="historyBox" spacing="6"
                  style="-fx-padding: 8; -fx-background-color: white;"/>
          </content>
        </ScrollPane>
      </VBox>

      <!-- Seitenleiste: Farben anpassen -->
      <VBox spacing="10"
            style="-fx-background-color: #e0e0e0; -fx-padding: 15; -fx-min-width: 180;">
        <Label text="🎨 Farben anpassen"
               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
        <Separator/>

        <Label text="R – Rot"/>
        <ColorPicker fx:id="colorPickerR" prefWidth="150"/>

        <Label text="G – Grün"/>
        <ColorPicker fx:id="colorPickerG" prefWidth="150"/>

        <Label text="B – Blau"/>
        <ColorPicker fx:id="colorPickerB" prefWidth="150"/>

        <Label text="Y – Gelb"/>
        <ColorPicker fx:id="colorPickerY" prefWidth="150"/>

        <Label text="O – Orange"/>
        <ColorPicker fx:id="colorPickerO" prefWidth="150"/>

        <Label text="P – Pink"/>
        <ColorPicker fx:id="colorPickerP" prefWidth="150"/>
      </VBox>

    </HBox>
  </center>

  <!-- UNTEN: Eingabe -->
  <bottom>
    <VBox spacing="8" style="-fx-background-color: #ececec; -fx-padding: 12;">
      <HBox spacing="10" style="-fx-alignment: center-left;">
        <Label text="Eingabe:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="guessField" prefWidth="200"/>
        <Button fx:id="submitButton" text="Versuch prüfen"
                style="-fx-background-color: #4caf50; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 4;"/>
        <Button fx:id="resetButton" text="Neues Spiel"
                style="-fx-background-color: #2196f3; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 4;"/>
      </HBox>
      <Label fx:id="messageLabel"
             style="-fx-text-fill: #c62828; -fx-font-weight: bold; -fx-font-size: 12px;"/>
    </VBox>
  </bottom>

</BorderPane>