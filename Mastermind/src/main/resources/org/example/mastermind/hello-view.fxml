<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

  <top>
    <VBox spacing="10">
      <padding>
        <Insets top="15" right="15" bottom="10" left="15"/>
      </padding>

      <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
      <Label fx:id="infoLabel"/>
      <Label fx:id="triesLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    </VBox>
  </top>

  <center>
    <VBox spacing="10">
      <padding>
        <Insets top="10" right="15" bottom="10" left="15"/>
      </padding>

      <Label text="Bisherige Versuche:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
      <TextArea fx:id="historyArea" prefHeight="280" wrapText="false"/>
    </VBox>
  </center>

  <bottom>
    <VBox spacing="10">
      <padding>
        <Insets top="10" right="15" bottom="15" left="15"/>
      </padding>

      <HBox spacing="10">
        <Label text="Eingabe:"/>
        <TextField fx:id="guessField" prefWidth="250"/>
        <Button fx:id="submitButton" text="Versuch prüfen"/>
        <Button fx:id="resetButton" text="Neues Spiel"/>
      </HBox>

      <Label fx:id="messageLabel" style="-fx-text-fill: darkred; -fx-font-weight: bold;"/>
    </VBox>
  </bottom>

</BorderPane>